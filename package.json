{
  "name": "eveable",
  "description": "Eveable is an alternative to Lovable built on Vercel Eve.",
  "version": "1.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.5.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "audit": "pnpm audit --prod --audit-level=critical",
    "build": "eve build",
    "ci": "pnpm run audit && pnpm run typecheck && pnpm run build && pnpm run smoke",
    "dev": "rm -rf .eve .output && eve dev",
    "smoke": "node scripts/smoke.mjs",
    "start": "eve start",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "@vercel/connect": "0.2.2",
    "ai": "7.0.0-beta.178",
    "eve": "^0.11.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "microsandbox": "^0.5.7"
  },
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "resolutions": {
    "ai": "7.0.0-beta.178"
  },
  "engines": {
    "node": ">=24 <27"
  }
}
